{
  "name": "pen-and-paper",
  "version": "0.0.0",
  "private": true,
  "description": "A catalogue of one reader's journey through fountain pens and paired papers.",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=payload.config.ts payload",
    "payload:generate-types": "pnpm payload generate:types",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "15",
    "react": "19",
    "react-dom": "19"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
